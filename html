<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AIC-25</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background-color: #A9A9A9;
      font-family: Arial, sans-serif;
      color: white;
      display: flex;
      padding: 10px;
      gap: 10px;
      height: 100vh;
    }

    .panel {
      border: 2px solid #F5F5F5;
      border-radius: 10px;
      padding: 10px;
    }

    .left-panel {
      width: 180px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .search-box {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border: 2px solid white;
      border-radius: 20px;
      padding: 5px 10px;
    }

    .tag {
      border: 2px solid white;
      border-radius: 20px;
      padding: 5px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .frame-options {
      border: 2px solid white;
      border-radius: 10px;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .option {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .toggle {
      width: 20px;
      height: 20px;
      border: 2px solid white;
      border-radius: 50%;
    }

    /* Cuộn cho middle panel */
    .middle-panel {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat (3, 1fr);
      gap: 10px;
      justify-items: center;
      align-items: center;
      max-height: 100%;
      overflow-y: auto;
    }

    .box {
      width: 120px;
      height: 80px;
      border: 2px solid white;
      border-radius: 15px;
      position: relative;
    }

    .box .oval {
      width: 50px;
      height: 10px;
      background: red;
      border-radius: 10px;
      position: absolute;
      bottom: 5px;
      right: 5px;
    }

    .box .rotate {
      position: absolute;
      top: 5px;
      left: 5px;
      font-size: 20px;
    }

    .right-panel {
      width: 180px;
      display: flex;
      flex-direction: column;
    }

    .right-panel-content {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .right-panel-footer {
      margin-top: auto;
      padding-top: 10px;
    }

    .recheck-title {
      font-size: 18px;
      margin-bottom: 5px;
      text-align: center;
    }

    .submit {
      border: 2px solid white;
      border-radius: 10px;
      padding: 10px 20px;
      font-weight: bold;
      text-align: center;
    }
    .
  </style>
</head>
